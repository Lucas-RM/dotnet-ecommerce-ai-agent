{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "LLM": {
    "Provider": "google",
    "OpenAI": {
      "ApiKey": "ADD_YOUR_OPENAI_API_KEY_HERE",
      "Model": "gpt-4o",
      "EmbeddingModel": "text-embedding-3-small"
    },
    "Google": {
      "ApiKey": "ADD_YOUR_GOOGLE_API_KEY_HERE",
      "Model": "gemini-2.5-flash",
      "MaxOutputTokens": 1024,
      "Temperature": 0.3
    }
  },
  "ECommerceApi": {
    "BaseUrl": "http://localhost:5149/api/v1",
    "TimeoutSeconds": 10,
    "RetryCount": 2
  },
  "Memory": {
    "Provider": "volatile",
    "Redis": {
      "ConnectionString": "localhost:6379"
    }
  },
  "Jwt": {
    "SecretKey": "CHANGE_THIS_TO_A_64_CHARACTER_MINIMUM_SECRET_KEY_ONLY_FOR_DEVELOPMENT_1234567890",
    "Issuer": "ECommerceApi",
    "Audience": "ECommerceClient"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200", "https://localhost:4200" ]
  },
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 524288
    }
  },
  "Agent": {
    "Observability": {
      "EnableMetrics": true,
      "EnableTraces": true
    },
    "Prompt": {
      "SystemPrompt": "",
      "Persona": "",
      "ToolPolicy": "",
      "Compliance": "",
      "Tone": ""
    },
    "Hosting": {
      "ChatRequestTimeoutSeconds": 120,
      "ShutdownTimeoutSeconds": 30,
      "ChatEndpointEnabled": true,
      "UseForwardedHeaders": false
    }
  },
  "Agents": {
    "DefaultAgentId": "support-general",
    "Catalog": [
      {
        "Id": "support-general",
        "DisplayName": "Atendimento Geral",
        "Description": "Agente generalista para dúvidas de loja e suporte inicial.",
        "LlmProvider": "OpenAI",
        "Model": "gpt-4o",
        "PromptTemplate": "Prompts/support-general.v1.system.md",
        "EnabledPlugins": [ "ProductPlugin", "OrderPlugin" ],
        "EnabledTools": [ "search_products", "get_product", "get_order", "list_orders" ],
        "ApprovalPolicy": "ByCapability"
      },
      {
        "Id": "sales-assistant",
        "DisplayName": "Assistente de Vendas",
        "Description": "Agente especializado em catálogo, recomendação e conversão.",
        "LlmProvider": "OpenAI",
        "Model": "gpt-4o",
        "PromptTemplate": "Prompts/sales-assistant.v1.system.md",
        "EnabledPlugins": [ "ProductPlugin", "CartPlugin" ],
        "EnabledTools": [ "search_products", "get_product", "get_cart", "add_cart_item", "update_cart_item", "remove_cart_item", "clear_cart" ],
        "ApprovalPolicy": "ByCapability"
      },
      {
        "Id": "order-tracker",
        "DisplayName": "Acompanhamento de Pedidos",
        "Description": "Agente dedicado ao ciclo de pedidos e status de entrega.",
        "LlmProvider": "OpenAI",
        "Model": "gpt-4o",
        "PromptTemplate": "Prompts/order-tracker.v1.system.md",
        "EnabledPlugins": [ "OrderPlugin" ],
        "EnabledTools": [ "get_order", "list_orders", "checkout" ],
        "ApprovalPolicy": "ByCapability"
      }
    ]
  },
  "OpenTelemetry": {
    "Agent": {
      "ServiceName": "ECommerce.AgentAPI-Development"
    }
  }
}
